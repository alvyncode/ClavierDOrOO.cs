<UserControl x:Class="Views.UserControls.QuestionLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Views.UserControls"
             xmlns:VM="clr-namespace:ViewModels"
             xmlns:VMU="clr-namespace:ViewModels.UserControls;assembly=ViewModels"
             xmlns:Views="clr-namespace:Views.UserControls"
             mc:Ignorable="d"
             Height="auto"
             Width="auto">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type VMU:OptionQuestionLayoutViewModel}">
            <Views:OptionQuestionLayout/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type VMU:OpenQuestionLayoutViewModel}">
            <Views:OpenQuestionLayout/>
        </DataTemplate>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,10,15,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Score : "
                           FontWeight="bold"
                           FontSize="32"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Score}"
                           FontSize="32"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="S a v e 💾"
                    Command="{Binding BoutonSave}"
                    Height="41"
                    FontSize="28"
                    FontFamily="Segoe UI Black"
                    FontWeight="Bold"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="Black"
                    Margin="0,8" />
        </StackPanel>
        <StackPanel Grid.Row="0"
                    Margin="20"
                    Width="auto"
                    Height="auto">
            <Border Background="{Binding MessageFeedbackColor}"
                    CornerRadius="10"
                    Padding="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{Binding IsMessageVisible, Converter={StaticResource BoolToVis}}">

                <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Center">

                    <TextBlock Text="{Binding MessageFeedback}"
                               Foreground="Black"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBlock Text="La Bonne réponse était : "
                                   Foreground="LightGray"
                                   FontSize="14"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding BonneReponse}"
                                   Foreground="LightGray"
                                   FontSize="14"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>
            </Border>
            <TextBlock Text="{Binding ThemeQuestion}"
                       FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="25"/>
            <Border BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="5"
                    Background="{Binding IntituleColor}"
                    Width="700"
                    Height="150">
                <TextBlock Padding="15"
                           Text="{Binding IntituleDelaQuestion}"
                           FontSize="32"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0"
                           Background="{Binding IntituleColor}"
                           Width="700"
                           Height="150"/>
            </Border>
        </StackPanel>
        <ContentControl Grid.Row="1"
                        Content="{Binding VueQCMouOption}"
                        Margin="20"/>
    </Grid>
</UserControl>