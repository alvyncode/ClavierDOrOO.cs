<UserControl x:Class="Views.UserControls.OpenQuestionLayout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Views.UserControls"
             mc:Ignorable="d"
             Height="auto" Width="auto">
    <StackPanel Orientation="Vertical" Width="650" Height="300" VerticalAlignment="Top" Margin = "0,90"> 
        <Border CornerRadius="15" Height="70" Background="White" HorizontalAlignment="Center" Width="650">
            <TextBox FontSize="32"
                    VerticalAlignment ="Center"
                    Text="{Binding Reponse}" 
                    Background="Transparent" 
                    BorderThickness="0"
                    Padding="15,10,15,10" 
                    Foreground="Black"
                    HorizontalAlignment="Center"
                    Height="65"
                    Width="650" />
        </Border>
        <Button Content="Confirmer"
                Command ="{Binding ValidationDesReponses}"
                CommandParameter ="{Binding Reponse}"
                FontWeight="Bold"
                HorizontalAlignment="Center"
                FontSize="32"
                VerticalAlignment="Center"
                Width="190" 
                Height="70"
                Margin = "0,50"
                Style="{StaticResource BoutonArrondi}"/>
    </StackPanel>
</UserControl>