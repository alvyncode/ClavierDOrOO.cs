<UserControl x:Class="Views.UserControls.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Views.UserControls"
             mc:Ignorable="d"
             Height="auto" Width="auto">
    <Grid Background="Gold">
        <StackPanel Orientation="Vertical"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="18,15,60,3">
            <TextBlock Text="CLAVIER D'OR"
                       FontSize="130"
                       FontFamily="Segoe UI"
                       Height="152"
                       Width="910"
                       TextAlignment="Left"
                       FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Connecté en tant que : "
                        FontSize="23"/>
                <TextBlock Text="{Binding PseudoDernierJoueur}"
                           FontWeight="Bold"
                        FontSize="23"/>
            </StackPanel>
        </StackPanel>
        <StackPanel Orientation="Vertical"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,0,10,10">
            <Button HorizontalContentAlignment="Left"
                    FontSize="32"
                    FontFamily="Segoe UI Black"
                    FontWeight="Bold"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="Black"
                    Width="250"
                    HorizontalAlignment="Left"
                    Content="N e w"
                    Command="{Binding BoutonNewGame}"
                    Padding="4"/>
            <Button HorizontalContentAlignment="Left"
                    HorizontalAlignment="Left"
                    FontSize="32"
                    FontFamily="Segoe UI Black"
                    FontWeight="Bold"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="Black"
                    Width="250"
                    Content="L o a d"
                    Command="{Binding BoutonLoad}"
                    Padding="4"/>
            <Button HorizontalContentAlignment="Left"
                    HorizontalAlignment="Left"
                    FontSize="32"
                    FontFamily="Segoe UI Black"
                    FontWeight="Bold"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="Black"
                    Width="250"
                    Content="H i s t o r y"
                    Command="{Binding BoutonHistory}"
                    Padding="4"/>
        </StackPanel>
        
    </Grid>
</UserControl>