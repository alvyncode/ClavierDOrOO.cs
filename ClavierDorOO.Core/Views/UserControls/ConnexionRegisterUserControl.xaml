<UserControl x:Class="Views.UserControls.ConnexionRegisterUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Views.UserControls"
             mc:Ignorable="d"
             Height="auto" Width="auto">
    <Grid>
        <TextBlock Text="CLAVIER D'OR"
                FontSize="130"
                Margin = "18,15,60,3"
                FontFamily="Segoe UI"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Height="152"
                Width="910"
                Grid.Row="0"
                TextAlignment="Left"
                FontWeight="Bold"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="auto" Height="auto" Orientation="Vertical" Margin ="0,100,0,0" >
            <Button Content="Connexion" Command="{Binding BoutonRLCommand}" Style="{StaticResource BoutonArrondi}" Foreground="Black" FontWeight="Bold" FontSize="32" Height="70" Width="400" Margin="0,15,0,15" Background="#FFF4FFF4"/>
            <Button Content="Invité" Command="{Binding BoutonInviteCommand}" Style="{StaticResource BoutonArrondi}" Foreground="Black" FontSize="32" Height="70" Width="400" FontWeight="Bold"  Margin="0,15,0,15" Background="#FFF4FFF4"/>
        </StackPanel>
    </Grid>
</UserControl>